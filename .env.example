# ─────────────────────────────────────────────────────────────
# Variables de entorno — RivieraMayaPass
# Copiá este archivo a .env.local y completá los valores.
# En producción se cargan en Vercel → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# ── Supabase (propiedades + panel admin) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Panel /admin ─────────────────────────────────────────────
ADMIN_PASSWORD=

# ── WhatsApp ─────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=529982017863

# ── Viator — afiliado (Fase 1: deep-links) ───────────────────
# Tu Partner ID, lo obtenés al ser aprobado en partners.viator.com/signup.
# Sin esto los tours funcionan pero SIN comisión.
NEXT_PUBLIC_VIATOR_PID=
# Opcionales (tienen default, normalmente no hace falta tocarlos):
# NEXT_PUBLIC_VIATOR_MCID=42383
# NEXT_PUBLIC_VIATOR_MEDIUM=link

# ── Viator — API (Fase 2: catálogo en vivo) ──────────────────
# Solo si pedís y te aprueban acceso "Basic-access affiliate" a la Partner API.
# Si está vacío, el sitio usa los tours curados de src/data/tours.ts (fallback).
VIATOR_API_KEY=
# Opcionales:
# VIATOR_DESTINATION_ID=631   # 631 = Cancún / Riviera Maya
# VIATOR_TOURS_COUNT=12

# ── Google Analytics 4 ───────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-QG60S7RX42

# ── Google Search Console ────────────────────────────────────
NEXT_PUBLIC_GSC_VERIFICATION=UKy1AA8CmDKjfKsrBfHD9NLeXxIVCteiVZix2z5zTPs
